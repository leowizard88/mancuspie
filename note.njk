---
layout: base.njk
title: Note
permalink: /note/
pageClass: internal
---
<section class="page-section hero internal-hero">
  <div class="image-field" aria-hidden="true"><i class="bg bg-mech"></i><i class="bg bg-score one"></i></div>
  <div class="hero-copy"><h1>Note</h1><div class="rule"></div><h2>Appunti e attraversamenti.</h2></div>
</section>
<section class="content-page list-page">
  <aside><p>Letture, immagini, ascolti, margini teorici.</p></aside>
  <div class="essay-list">
    {% for item in collections.note | reverse %}
    <article class="essay"><h3><a href="{{ item.url }}">{{ item.data.title }}</a></h3><p>{{ item.data.author }}{% if item.data.excerpt %} · {{ item.data.excerpt }}{% endif %}</p></article>
    {% endfor %}
  </div>
</section>
